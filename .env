# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=healthsymphony
DB_PORT=3306

# You can replace the above with remote database credentials
# Example: 
# DB_HOST=your-remote-db-host.com
# DB_USER=admin
# DB_PASSWORD=your_secure_password
# DB_NAME=remote_db
# DB_PORT=3306

# Flask Configuration
FLASK_SECRET_KEY=super_secure_random_key_123

# Flask-Mail Settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Twilio Settings
TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Admin
ADMIN_PHONE=+916383649156
